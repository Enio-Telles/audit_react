{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audit React",
  "version": "0.1.0",
  "identifier": "io.eniotelles.auditreact",
  "build": {
    "beforeDevCommand": "python ../app_react.py --no-browser",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Audit React",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
