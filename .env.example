# Oracle principal
ORACLE_HOST=oracle-host.exemplo.gov.br
ORACLE_PORT=1521
ORACLE_SERVICE=sefindw
DB_USER=seu_usuario_oracle
DB_PASSWORD=sua_senha_oracle

# Oracle secundario (opcional)
ORACLE_HOST_1=
ORACLE_PORT_1=1521
ORACLE_SERVICE_1=
DB_USER_1=
DB_PASSWORD_1=

# Backend
STORAGE_BASE_DIR=./storage/CNPJ
LOG_LEVEL=INFO
SQL_QUERIES_DIR=./server/python/consultas
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000
RELATORIO_MODELO_INDIVIDUAL_DOCX=
RELATORIO_MODELO_GERAL_DOCX=

# Frontend/gateway
PYTHON_API_URL=http://localhost:8000
PORT=3000

# Mapeamento de fontes Oracle usadas pelos SQLs versionados (placeholders {{FONTE_*}})
ORACLE_FONTE_NFE=BI.FATO_NFE_DETALHE
ORACLE_FONTE_NFCE=BI.FATO_NFCE_DETALHE
ORACLE_FONTE_C100=SPED.REG_C100
ORACLE_FONTE_C170=SPED.REG_C170
ORACLE_FONTE_REG0000=SPED.REG_0000
ORACLE_FONTE_REG0200=SPED.REG_0200
ORACLE_FONTE_REG0205=SPED.REG_0205
ORACLE_FONTE_REG0220=SPED.REG_0220
ORACLE_FONTE_BLOCO_H_CAB=SPED.REG_H005
ORACLE_FONTE_BLOCO_H_ITEM=SPED.REG_H010
ORACLE_FONTE_BLOCO_H_TRIB=SPED.REG_H020
