@router.post("/query")
def query_parquet(req: QueryRequest):
    try:
        if ".." in req.path:
            raise ValueError("Path traversal detectado")

        req_p = Path(req.path)
        if req_p.is_absolute():
            p = req_p.resolve()
        else:
            p = (CNPJ_ROOT / req_p).resolve()

        if not p.is_relative_to(CNPJ_ROOT.resolve()):
            raise ValueError()
    except Exception:
